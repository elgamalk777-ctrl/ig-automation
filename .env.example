# Long-lived Instagram User/Page Access Token (see README for how to generate)
INSTAGRAM_ACCESS_TOKEN=

# Your Instagram Business Account ID (numeric, from Graph API Explorer)
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Found in Facebook Developer App > Settings > Basic
FACEBOOK_APP_SECRET=

# Any random string you choose — must match what you enter in the
# Facebook App's Webhook configuration screen
WEBHOOK_VERIFY_TOKEN=

# SQLite by default; swap for a Postgres URL in production
DATABASE_URL=sqlite:///./app.db
